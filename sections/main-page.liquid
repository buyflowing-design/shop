

{% liquid
  assign is_contact_page = false
  if template.suffix == 'contact' or page.handle contains 'contact'
    assign is_contact_page = true
  endif
%}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section{% unless is_contact_page %} page-width-content{% endunless %} color-{{ section.settings.color_scheme }}{% if is_contact_page %} sf-contact-fallback{% endif %}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {% if is_contact_page %}
      <div class="sfc__bg"></div>
      <div class="sfc__inner">
        <h1 class="sfc__title">{{ page.title }}</h1>
        {% if page.content != blank %}
          <div class="sfc__subtitle rte">{{ page.content }}</div>
        {% endif %}
        {%- form 'contact', id: 'ScaleFlowContactFallback', class: 'sfc__form sfc__glass' -%}
          {%- if form.posted_successfully? -%}
            <p class="sfc__alert sfc__alert--success">Mensaje enviado. Te contactaremos pronto.</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="sfc__alert sfc__alert--error">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </p>
          {%- endif -%}
          <div class="sfc__row">
            <input class="sfc__input" type="text" name="contact[name]" autocomplete="name" placeholder="Tu nombre">
            <input class="sfc__input" type="email" name="contact[email]" autocomplete="email" placeholder="tu@email.com" required>
          </div>
          <input class="sfc__input" type="tel" name="contact[phone]" autocomplete="tel" placeholder="Tu telefono (opcional)">
          <textarea class="sfc__input sfc__textarea" name="contact[body]" rows="7" placeholder="Cuéntanos tu caso y objetivo..."></textarea>
          <button type="submit" class="sfc__button">Enviar mensaje</button>
        {%- endform -%}
      </div>
    {% else %}
      {% content_for 'blocks' %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .sf-contact-fallback {
    --bg: #050505;
    --cyan: #00f5ff;
    --indigo: #6366f1;
    --text: #ffffff;
    --muted: #94a3b8;
    color: var(--text);
    background: var(--bg);
    position: relative;
    overflow: clip;
    padding-inline: clamp(1rem, 2.8vw, 2rem);
    max-width: none !important;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
  }

  .sf-contact-fallback .section-content-wrapper {
    position: relative;
    width: 100%;
    max-width: none !important;
  }

  .sf-contact-fallback .sfc__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(900px 520px at 10% 6%, rgb(0 245 255 / 16%), transparent 58%),
      radial-gradient(900px 580px at 86% 84%, rgb(99 102 241 / 18%), transparent 62%);
  }

  .sf-contact-fallback .sfc__inner {
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .sf-contact-fallback .sfc__title {
    margin: 0;
    font: 800 clamp(2rem, 6vw, 4rem) / 1.04 Outfit, Inter, sans-serif;
    color: #fff;
  }

  .sf-contact-fallback .sfc__subtitle {
    margin: 1rem auto 0;
    max-width: 680px;
    color: var(--muted);
  }

  .sf-contact-fallback .sfc__glass {
    margin-top: 2rem;
    border: 1px solid rgb(255 255 255 / 12%);
    border-radius: 24px;
    background: linear-gradient(150deg, rgb(15 23 42 / 74%), rgb(15 23 42 / 56%));
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 12%), 0 20px 38px rgb(0 0 0 / 32%);
    padding: clamp(1rem, 2.2vw, 1.8rem);
  }

  .sf-contact-fallback .sfc__form {
    display: grid;
    gap: 0.8rem;
  }

  .sf-contact-fallback .sfc__row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .sf-contact-fallback .sfc__input {
    min-height: 52px;
    border-radius: 12px;
    border: 1px solid rgb(255 255 255 / 16%);
    background: rgb(8 15 30 / 72%);
    color: #f0f7ff;
    padding: 0.8rem 0.9rem;
  }

  .sf-contact-fallback .sfc__input::placeholder {
    color: #9db0c8;
  }

  .sf-contact-fallback .sfc__textarea {
    min-height: 180px;
    resize: vertical;
  }

  .sf-contact-fallback .sfc__button {
    min-height: 52px;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--cyan), var(--indigo));
    color: #031018;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 0 20px rgb(0 245 255 / 26%);
  }

  .sf-contact-fallback .sfc__alert {
    margin: 0;
    border-radius: 10px;
    padding: 0.65rem 0.8rem;
    font-size: 0.9rem;
  }

  .sf-contact-fallback .sfc__alert--success {
    border: 1px solid rgb(34 197 94 / 35%);
    background: rgb(34 197 94 / 16%);
    color: #9ff7c4;
  }

  .sf-contact-fallback .sfc__alert--error {
    border: 1px solid rgb(239 68 68 / 35%);
    background: rgb(239 68 68 / 16%);
    color: #ffc2c2;
  }

  @media screen and (max-width: 720px) {
    .sf-contact-fallback .sfc__row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.page",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
