    { "type": "textarea", "id": "proof_text", "label": "Texto proof", "default": "Construido por operadores, validado en las trincheras y respaldado por miles de fundadores escalando negocios reales." },
    { "type": "text", "id": "faq_kicker", "label": "Kicker FAQ", "default": "PREGUNTAS FRECUENTES" },
    { "type": "text", "id": "faq_title", "label": "Titulo FAQ", "default": "Todo Lo Que Necesitas Saber" },
    { "type": "textarea", "id": "faq_text", "label": "Texto FAQ", "default": "Sin rodeos - solo respuestas." },
    { "type": "text", "id": "closing_kicker", "label": "Kicker cierre", "default": "TU PROXIMO PASO" },
    { "type": "text", "id": "closing_title", "label": "Titulo cierre", "default": "¿Listo para Escalar Mas Inteligente?" },
    { "type": "textarea", "id": "closing_text", "label": "Texto cierre", "default": "Unete a mas de 12.000 fundadores que ya han transformado su negocio con los sistemas de Scale Flow." },
    { "type": "text", "id": "closing_cta_label", "label": "CTA cierre", "default": "Empieza a Escalar Ahora" },
