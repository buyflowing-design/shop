    { "type": "proof_item", "name": "Proof item", "settings": [ { "type": "text", "id": "icon", "label": "Icono", "default": "+" }, { "type": "text", "id": "title", "label": "Titulo", "default": "Verificado por Expertos" }, { "type": "textarea", "id": "text", "label": "Texto", "default": "Cada guia revisada por operadores activos." } ] },
    { "type": "stat_item", "name": "Stat item", "settings": [ { "type": "text", "id": "metric", "label": "Numero", "default": "12K+" }, { "type": "text", "id": "label", "label": "Etiqueta", "default": "Fundadores" } ] },
    { "type": "faq_item", "name": "FAQ item", "settings": [ { "type": "text", "id": "question", "label": "Pregunta", "default": "¿Tengo acceso de por vida?" }, { "type": "textarea", "id": "answer", "label": "Respuesta", "default": "Si. Cada compra incluye acceso de por vida y todas las actualizaciones futuras." } ] },
    { "type": "log_step", "name": "Flow step", "settings": [ { "type": "text", "id": "title", "label": "Titulo", "default": "Step 1: Expert Extraction" }, { "type": "textarea", "id": "text", "label": "Texto", "default": "Extraemos la estrategia de un profesional top." } ] }
  ],
  "presets": [
    {
      "name": "Scale Flow Home",
      "blocks": {
        "lab_1": { "type": "lab_item", "settings": { "icon": "+", "title": "Experiencia Humana", "text": "Curado por operadores reales que han construido y escalado negocios de verdad." } },
