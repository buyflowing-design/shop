{% liquid
  assign featured_collection = section.settings.featured_collection
  assign featured_limit = section.settings.featured_products_limit
%}

<section
  id="ScaleFlow-{{ section.id }}"
  class="scale-flow spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="scale-flow__bg-texture"></div>

  <div class="scale-flow__hero scale-flow__glass-panel">
    <div class="scale-flow__floating-layer" aria-hidden="true">
      <span class="scale-flow__shape scale-flow__shape--sphere" data-speed="0.015"></span>
      <span class="scale-flow__shape scale-flow__shape--cube" data-speed="0.025"></span>
      <span class="scale-flow__shape scale-flow__shape--thread" data-speed="0.02"></span>
      <span class="scale-flow__shape scale-flow__shape--sphere scale-flow__shape--small" data-speed="0.03"></span>
    </div>

    <div class="scale-flow__hero-content">
      <p class="scale-flow__badge">{{ section.settings.hero_badge }}</p>
      <h1>{{ section.settings.hero_title }}</h1>
      <p class="scale-flow__hero-copy">{{ section.settings.hero_text }}</p>
      {% if section.settings.hero_cta_label != blank %}
        <a class="scale-flow__cta" href="{{ section.settings.hero_cta_link | default: '#' }}">
          {{ section.settings.hero_cta_label }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="scale-flow__section scale-flow__lab scale-flow__glass-panel">
    <div class="scale-flow__section-heading">
      <p>{{ section.settings.lab_kicker }}</p>
      <h2>{{ section.settings.lab_title }}</h2>
      <p class="scale-flow__section-copy">{{ section.settings.lab_text }}</p>
    </div>
    <div class="scale-flow__lab-grid">
      {% for block in section.blocks %}
        {% if block.type == 'lab_item' %}
          <article class="scale-flow__lab-card" {{ block.shopify_attributes }}>
            <span class="scale-flow__lab-icon">{{ block.settings.icon }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="scale-flow__section scale-flow__streams scale-flow__glass-panel">
    <div class="scale-flow__floating-layer scale-flow__floating-layer--products" aria-hidden="true">
      <span class="scale-flow__shape scale-flow__shape--thread scale-flow__shape--wide" data-speed="0.012"></span>
      <span class="scale-flow__shape scale-flow__shape--cube scale-flow__shape--small" data-speed="0.02"></span>
      <span class="scale-flow__shape scale-flow__shape--sphere" data-speed="0.017"></span>
    </div>

    <div class="scale-flow__section-heading">
      <p>{{ section.settings.featured_kicker }}</p>
      <h2>{{ section.settings.featured_title }}</h2>
      <p class="scale-flow__section-copy">{{ section.settings.featured_text }}</p>
    </div>

    <div class="scale-flow__streams-grid">
      {% for block in section.blocks %}
        {% if block.type == 'stream_item' %}
          <article class="scale-flow__stream-card" {{ block.shopify_attributes }}>
            <p class="scale-flow__stream-label">{{ block.settings.label }}</p>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div class="scale-flow__product-grid">
      {% if featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: featured_limit %}
          <article class="scale-flow__product-card">
            <a href="{{ product.url }}" class="scale-flow__product-link">
              <div class="scale-flow__product-media">
                {% if product.featured_image != blank %}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag:
                      widths: '360, 480, 720, 800',
                      loading: 'lazy',
                      class: 'scale-flow__product-image',
                      alt: product.featured_image.alt | default: product.title
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'scale-flow__product-placeholder' }}
                {% endif %}
              </div>
              <div class="scale-flow__product-content">
                <h3>{{ product.title }}</h3>
                <div class="scale-flow__price">
                  {{ product.price | money }}
                </div>
              </div>
            </a>
          </article>
        {% endfor %}
      {% else %}
        {% for index in (1..featured_limit) %}
          <article class="scale-flow__product-card">
            <div class="scale-flow__product-media">
              {{ 'product-' | append: index | placeholder_svg_tag: 'scale-flow__product-placeholder' }}
            </div>
            <div class="scale-flow__product-content">
              <h3>Digital Blueprint {{ index }}</h3>
              <div class="scale-flow__price">$99.00</div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <div class="scale-flow__section scale-flow__faq scale-flow__glass-panel">
  <div class="scale-flow__section scale-flow__proof scale-flow__glass-panel">
    <div class="scale-flow__section-heading">
      <p>{{ section.settings.proof_kicker }}</p>
      <h2>{{ section.settings.proof_title }}</h2>
      <p class="scale-flow__section-copy">{{ section.settings.proof_text }}</p>
    </div>
    <div class="scale-flow__proof-grid">
      {% for block in section.blocks %}
        {% if block.type == 'proof_item' %}
          <article class="scale-flow__proof-card" {{ block.shopify_attributes }}>
            <span class="scale-flow__lab-icon">{{ block.settings.icon }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
    <div class="scale-flow__stats-grid">
      {% for block in section.blocks %}
        {% if block.type == 'stat_item' %}
          <article class="scale-flow__stat-card" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.metric }}</h3>
            <p>{{ block.settings.label }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="scale-flow__section scale-flow__faq scale-flow__glass-panel">
    <div class="scale-flow__section-heading">
      <p>{{ section.settings.faq_kicker }}</p>
      <h2>{{ section.settings.faq_title }}</h2>
    </div>
    <div class="scale-flow__faq-list">
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          <details class="scale-flow__faq-item" {{ block.shopify_attributes }}>
            <summary>
              <span class="scale-flow__faq-dot"></span>
              {{ block.settings.question }}
            </summary>
            <div class="scale-flow__faq-answer">{{ block.settings.answer }}</div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  body:has(.scale-flow) {
    background: #050505;
  }

  .content-for-layout:has(.scale-flow) {
    background: #050505;
  }

  body:has(.scale-flow) footer {
    background: #050505;
    border-top: 1px solid rgb(255 255 255 / 8%);
  }

  .scale-flow {
    --sf-bg: #050505;
    --sf-glass: rgb(30 41 59 / 60%);
    --sf-cyan: #00f5ff;
    --sf-indigo: #6366f1;
    --sf-title: #ffffff;
    --sf-body: #94a3b8;
    position: relative;
    overflow: clip;
    background: radial-gradient(circle at 20% 20%, rgb(0 245 255 / 10%), transparent 40%),
      radial-gradient(circle at 80% 10%, rgb(99 102 241 / 16%), transparent 30%), var(--sf-bg);
    color: var(--sf-body);
    padding-inline: clamp(1rem, 4vw, 3rem);
  }

  .scale-flow__bg-texture {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgb(255 255 255 / 2%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / 2%) 1px, transparent 1px);
    background-size: 44px 44px;
    opacity: 0.2;
    pointer-events: none;
    z-index: 0;
  }

  .scale-flow__hero,
  .scale-flow__section {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin-inline: auto;
    margin-block: 0 clamp(2.5rem, 7vw, 5.5rem);
  }

  .scale-flow__glass-panel {
    border: 1px solid rgb(255 255 255 / 14%);
    background: linear-gradient(140deg, rgb(30 41 59 / 70%), rgb(30 41 59 / 40%));
    backdrop-filter: blur(18px);
    border-radius: 28px;
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 24%), 0 24px 60px rgb(0 0 0 / 42%);
  }

  .scale-flow__hero {
    min-height: min(78svh, 820px);
    display: grid;
    place-items: center;
    text-align: center;
    isolation: isolate;
    padding: clamp(2.5rem, 8vw, 7rem) clamp(1.4rem, 6vw, 6rem);
  }

  .scale-flow__hero-content {
    max-width: 820px;
  }

  .scale-flow h1,
  .scale-flow h2,
  .scale-flow h3 {
    color: var(--sf-title);
    font-family: Outfit, Syne, "Segoe UI", sans-serif;
    letter-spacing: 0.02em;
  }

  .scale-flow h1 {
    margin: 0.75rem 0 1rem;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.08;
  }

  .scale-flow__hero-copy,
  .scale-flow__section-copy {
    font-family: Inter, Montserrat, "Segoe UI", sans-serif;
    color: var(--sf-body);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    line-height: 1.6;
    max-width: 72ch;
    margin-inline: auto;
  }

  .scale-flow__badge {
    display: inline-flex;
    border-radius: 999px;
    border: 1px solid rgb(0 245 255 / 40%);
    background: rgb(0 245 255 / 12%);
    padding: 0.38rem 1rem;
    color: #d8fbff;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.74rem;
    font-weight: 700;
  }

  .scale-flow__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.7rem;
    padding: 0.9rem 1.65rem;
    border-radius: 14px;
    color: #05121f;
    font-weight: 700;
    text-decoration: none;
    background: linear-gradient(120deg, var(--sf-cyan), var(--sf-indigo));
    box-shadow: 0 0 20px rgb(0 245 255 / 35%);
    transition: transform 120ms ease, box-shadow 140ms ease;
  }

  .scale-flow__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 26px rgb(99 102 241 / 46%);
  }

  .scale-flow__section {
    padding: clamp(1.4rem, 4vw, 3rem);
  }

  .scale-flow__section-heading {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .scale-flow__section-heading p:first-child {
    margin: 0;
    color: var(--sf-cyan);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .scale-flow h2 {
    margin: 0.55rem 0 0.7rem;
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    line-height: 1.15;
  }

  .scale-flow__lab-grid,
  .scale-flow__streams-grid,
  .scale-flow__product-grid,
  .scale-flow__proof-grid,
  .scale-flow__stats-grid {
    display: grid;
    gap: 1rem;
  }

  .scale-flow__lab-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .scale-flow__lab-card,
  .scale-flow__stream-card,
  .scale-flow__product-card,
  .scale-flow__proof-card,
  .scale-flow__stat-card {
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 18px;
    background: rgb(15 23 42 / 45%);
    padding: 1.1rem;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .scale-flow__lab-card:hover,
  .scale-flow__stream-card:hover,
  .scale-flow__product-card:hover,
  .scale-flow__proof-card:hover,
  .scale-flow__stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 20px rgb(0 245 255 / 16%);
    border-color: rgb(0 245 255 / 35%);
  }

  .scale-flow__lab-icon {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    margin-bottom: 0.75rem;
    font-size: 1.2rem;
    background: rgb(0 245 255 / 15%);
    color: var(--sf-cyan);
    box-shadow: 0 0 18px rgb(0 245 255 / 26%);
  }

  .scale-flow__lab-card h3,
  .scale-flow__stream-card h3,
  .scale-flow__product-content h3 {
    margin: 0 0 0.4rem;
    font-size: 1.12rem;
  }

  .scale-flow__lab-card p,
  .scale-flow__stream-card p,
  .scale-flow__faq-answer {
    margin: 0;
    line-height: 1.5;
  }

  .scale-flow__streams-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 1.2rem;
  }

  .scale-flow__proof-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 1rem;
  }

  .scale-flow__stats-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .scale-flow__stat-card {
    text-align: center;
  }

  .scale-flow__stat-card h3 {
    margin: 0;
    color: var(--sf-cyan);
    font-size: clamp(1.4rem, 3vw, 2rem);
  }

  .scale-flow__stat-card p {
    margin: 0.35rem 0 0;
  }

  .scale-flow__stream-label {
    color: var(--sf-cyan);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.74rem;
    font-weight: 700;
    margin-bottom: 0.45rem;
  }

  .scale-flow__streams {
    overflow: hidden;
    isolation: isolate;
  }

  .scale-flow__product-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .scale-flow__product-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .scale-flow__product-media {
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 0.7rem;
    aspect-ratio: 16 / 11;
    background: rgb(0 0 0 / 20%);
  }

  .scale-flow__product-image,
  .scale-flow__product-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .scale-flow__price {
    color: var(--sf-cyan);
    font-weight: 700;
  }

  .scale-flow__faq-list {
    display: grid;
    gap: 0.7rem;
  }

  .scale-flow__faq-item {
    border: 1px solid rgb(255 255 255 / 12%);
    border-radius: 14px;
    padding: 0.85rem 0.95rem;
    background: rgb(15 23 42 / 42%);
  }

  .scale-flow__faq-item summary {
    list-style: none;
    display: flex;
    gap: 0.7rem;
    align-items: center;
    color: #fff;
    cursor: pointer;
    font-weight: 600;
  }

  .scale-flow__faq-item summary::-webkit-details-marker {
    display: none;
  }

  .scale-flow__faq-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--sf-cyan);
    box-shadow: 0 0 14px rgb(0 245 255 / 62%);
    flex: 0 0 auto;
  }

  .scale-flow__faq-answer {
    margin-top: 0.7rem;
    padding-left: 1.7rem;
  }

  .scale-flow__floating-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  .scale-flow__shape {
    position: absolute;
    display: block;
    border-radius: 999px;
    transform: translate3d(0, 0, 0);
    animation: sf-float 10s ease-in-out infinite;
    will-change: transform;
    background: linear-gradient(160deg, rgb(0 245 255 / 36%), rgb(99 102 241 / 38%));
    border: 1px solid rgb(255 255 255 / 25%);
    box-shadow: inset 0 1px 8px rgb(255 255 255 / 18%), 0 0 16px rgb(0 245 255 / 28%);
    backdrop-filter: blur(6px);
  }

  .scale-flow__shape--sphere {
    width: clamp(90px, 10vw, 150px);
    height: clamp(90px, 10vw, 150px);
    top: 12%;
    left: 6%;
  }

  .scale-flow__shape--cube {
    width: clamp(72px, 8vw, 122px);
    height: clamp(72px, 8vw, 122px);
    border-radius: 24px;
    right: 10%;
    top: 18%;
    animation-duration: 12s;
  }

  .scale-flow__shape--thread {
    width: 220px;
    height: 80px;
    border-radius: 999px;
    bottom: 12%;
    right: 18%;
    transform: rotate(-12deg);
    animation-duration: 14s;
  }

  .scale-flow__shape--small {
    width: 58px;
    height: 58px;
    top: 67%;
    left: 19%;
    animation-duration: 11s;
  }

  .scale-flow__shape--wide {
    width: min(32vw, 320px);
    left: 9%;
    top: 9%;
  }

  @keyframes sf-float {
    0% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(0, -14px, 0);
    }
    100% {
      transform: translate3d(0, 0, 0);
    }
  }

  @media screen and (max-width: 990px) {
    .scale-flow__lab-grid,
    .scale-flow__streams-grid,
    .scale-flow__product-grid,
    .scale-flow__proof-grid,
    .scale-flow__stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 740px) {
    .scale-flow__lab-grid,
    .scale-flow__streams-grid,
    .scale-flow__product-grid,
    .scale-flow__proof-grid,
    .scale-flow__stats-grid {
      grid-template-columns: 1fr;
    }

    .scale-flow__shape--thread,
    .scale-flow__shape--wide {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scale-flow__shape {
      animation: none;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const root = document.getElementById('ScaleFlow-{{ section.id }}');
    if (!root || root.dataset.flowInit === 'true') return;

    root.dataset.flowInit = 'true';
    const shapes = Array.from(root.querySelectorAll('.scale-flow__shape[data-speed]'));
    if (!shapes.length) return;

    const pointer = { x: 0, y: 0 };
    const state = { x: 0, y: 0 };

    const updatePointer = (event) => {
      const bounds = root.getBoundingClientRect();
      pointer.x = ((event.clientX - bounds.left) / bounds.width - 0.5) * 2;
      pointer.y = ((event.clientY - bounds.top) / bounds.height - 0.5) * 2;
    };

    root.addEventListener('pointermove', updatePointer, { passive: true });

    const onScroll = () => {
      const bounds = root.getBoundingClientRect();
      const factor = Math.max(-1, Math.min(1, -bounds.top / window.innerHeight));
      pointer.y = factor * 0.8;
    };

    window.addEventListener('scroll', onScroll, { passive: true });

    const animate = () => {
      state.x += (pointer.x - state.x) * 0.06;
      state.y += (pointer.y - state.y) * 0.06;

      shapes.forEach((shape) => {
        const speed = Number(shape.dataset.speed || 0.02);
        const x = state.x * (speed * 100) * 8;
        const y = state.y * (speed * 100) * 8;
        shape.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      });

      window.requestAnimationFrame(animate);
    };

    window.requestAnimationFrame(animate);
  })();
</script>

