        "stream_3": { "type": "stream_item", "settings": { "icon": "⌘", "label": "OPERACIONES E IA", "title": "BizScale", "text": "Automatiza tus operaciones y gana apalancamiento con SOPs y blueprints potenciados por IA." } },
        "proof_1": { "type": "proof_item", "settings": { "icon": "✓", "title": "Verificado por Expertos", "text": "Cada guia revisada por operadores activos con negocios de 7 cifras." } },
        "proof_2": { "type": "proof_item", "settings": { "icon": "🚀", "title": "Listo para Implementar", "text": "Sin teoria - frameworks listos para ejecutar desde el primer dia." } },
        "proof_3": { "type": "proof_item", "settings": { "icon": "🤖", "title": "Potenciado por IA", "text": "Sistemas testeados y optimizados con las ultimas herramientas de IA." } },
        "proof_4": { "type": "proof_item", "settings": { "icon": "🔒", "title": "Resultados Garantizados", "text": "Si no ves resultados, lo solucionamos." } },
        "faq_1": { "type": "faq_item", "settings": { "question": "¿Que hay exactamente dentro de un producto de Scale Flow?", "answer": "Guias, prompts, SOPs y plantillas listas para aplicar." } },
        "faq_2": { "type": "faq_item", "settings": { "question": "¿Es para principiantes o emprendedores avanzados?", "answer": "Funciona para ambos niveles gracias a su estructura modular." } },
        "faq_3": { "type": "faq_item", "settings": { "question": "¿Tengo acceso de por vida?", "answer": "Si. Incluye acceso de por vida y actualizaciones futuras." } }
      },
      "block_order": ["lab_1", "lab_2", "lab_3", "stream_1", "stream_2", "stream_3", "proof_1", "proof_2", "proof_3", "proof_4", "faq_1", "faq_2", "faq_3"]
    }
  ]
