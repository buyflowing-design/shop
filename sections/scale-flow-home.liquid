{% liquid
  assign featured_collection = section.settings.featured_collection
  assign featured_limit = section.settings.featured_products_limit
%}

<section id="ScaleFlow-{{ section.id }}" class="scale-flow spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="scale-flow__bg-texture"></div>

  <div class="scale-flow__hero scale-flow__glass-panel">
    <div class="scale-flow__floating-layer" aria-hidden="true">
      <span class="scale-flow__shape scale-flow__shape--sphere" data-speed="0.015"></span>
      <span class="scale-flow__shape scale-flow__shape--cube" data-speed="0.025"></span>
      <span class="scale-flow__shape scale-flow__shape--thread" data-speed="0.02"></span>
      <span class="scale-flow__shape scale-flow__shape--sphere scale-flow__shape--small" data-speed="0.03"></span>
    </div>
    <div class="scale-flow__hero-content">
      <p class="scale-flow__badge">{{ section.settings.hero_badge }}</p>
      <h1>{{ section.settings.hero_title }}</h1>
      <h1 class="scale-flow__hero-title-alt">{{ section.settings.hero_title_alt }}</h1>
      <p class="scale-flow__hero-copy">{{ section.settings.hero_text }}</p>
      <div class="scale-flow__hero-ctas">
        <a class="scale-flow__cta" href="{{ section.settings.hero_cta_link | default: '#' }}">{{ section.settings.hero_cta_label }}</a>
        {% if section.settings.hero_secondary_cta_label != blank %}
          <a class="scale-flow__cta scale-flow__cta--ghost" href="{{ section.settings.hero_secondary_cta_link | default: '#' }}">{{ section.settings.hero_secondary_cta_label }}</a>
        {% endif %}
      </div>
    </div>
    <div class="scale-flow__trust-row"><span>{{ section.settings.trust_1 }}</span><span>{{ section.settings.trust_2 }}</span><span>{{ section.settings.trust_3 }}</span></div>
  </div>

  <div class="scale-flow__section scale-flow__glass-panel">
    <div class="scale-flow__section-heading"><p>{{ section.settings.lab_kicker }}</p><h2>{{ section.settings.lab_title }}</h2><p class="scale-flow__section-copy">{{ section.settings.lab_text }}</p></div>
    <div class="scale-flow__lab-grid">{% for block in section.blocks %}{% if block.type == 'lab_item' %}<article class="scale-flow__card" {{ block.shopify_attributes }}><span class="scale-flow__lab-icon">{{ block.settings.icon }}</span><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p></article>{% endif %}{% endfor %}</div>
  </div>

  <div class="scale-flow__section scale-flow__glass-panel">
    <div class="scale-flow__floating-layer scale-flow__floating-layer--products" aria-hidden="true">
      <span class="scale-flow__shape scale-flow__shape--thread scale-flow__shape--wide" data-speed="0.012"></span>
      <span class="scale-flow__shape scale-flow__shape--cube scale-flow__shape--small" data-speed="0.02"></span>
      <span class="scale-flow__shape scale-flow__shape--sphere" data-speed="0.017"></span>
    </div>
    <div class="scale-flow__section-heading"><p>{{ section.settings.featured_kicker }}</p><h2>{{ section.settings.featured_title }}</h2><p class="scale-flow__section-copy">{{ section.settings.featured_text }}</p></div>
    <div class="scale-flow__streams-grid">{% for block in section.blocks %}{% if block.type == 'stream_item' %}<article class="scale-flow__card" {{ block.shopify_attributes }}><p class="scale-flow__stream-label">{{ block.settings.label }}</p><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p><a class="scale-flow__stream-link" href="{{ block.settings.link | default: '#' }}">{{ section.settings.stream_cta_label }}</a></article>{% endif %}{% endfor %}</div>
    <div class="scale-flow__product-grid">
      {% if featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: featured_limit %}
          <article class="scale-flow__card"><a href="{{ product.url }}" class="scale-flow__product-link"><div class="scale-flow__product-media">{% if product.featured_image %}{{ product.featured_image | image_url: width: 800 | image_tag: class: 'scale-flow__product-image', widths: '360, 480, 720, 800', loading: 'lazy', alt: product.title }}{% else %}{{ 'product-1' | placeholder_svg_tag: 'scale-flow__product-placeholder' }}{% endif %}</div><h3>{{ product.title }}</h3><div class="scale-flow__price">{{ product.price | money }}</div></a></article>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <div class="scale-flow__section scale-flow__glass-panel">
    <div class="scale-flow__section-heading"><p>{{ section.settings.proof_kicker }}</p><h2>{{ section.settings.proof_title }}</h2><p class="scale-flow__section-copy">{{ section.settings.proof_text }}</p></div>
    <div class="scale-flow__proof-grid">{% for block in section.blocks %}{% if block.type == 'proof_item' %}<article class="scale-flow__card" {{ block.shopify_attributes }}><span class="scale-flow__lab-icon">{{ block.settings.icon }}</span><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p></article>{% endif %}{% endfor %}</div>
    <div class="scale-flow__stats-grid">{% for block in section.blocks %}{% if block.type == 'stat_item' %}<article class="scale-flow__card scale-flow__stat-card" {{ block.shopify_attributes }}><h3>{{ block.settings.metric }}</h3><p>{{ block.settings.label }}</p></article>{% endif %}{% endfor %}</div>
  </div>

  <div class="scale-flow__section scale-flow__glass-panel">
    <div class="scale-flow__section-heading"><p>{{ section.settings.faq_kicker }}</p><h2>{{ section.settings.faq_title }}</h2><p class="scale-flow__section-copy">{{ section.settings.faq_text }}</p></div>
    <div class="scale-flow__faq-list">{% for block in section.blocks %}{% if block.type == 'faq_item' %}<details class="scale-flow__faq-item" {{ block.shopify_attributes }}><summary><span class="scale-flow__faq-dot"></span>{{ block.settings.question }}</summary><div class="scale-flow__faq-answer">{{ block.settings.answer }}</div></details>{% endif %}{% endfor %}</div>
    <div class="scale-flow__faq-contact"><p>{{ section.settings.faq_contact_text }}</p><a href="{{ section.settings.faq_contact_link | default: '#' }}">{{ section.settings.faq_contact_label }}</a></div>
  </div>

  <div class="scale-flow__section scale-flow__closing scale-flow__glass-panel"><p class="scale-flow__badge">{{ section.settings.closing_kicker }}</p><h2>{{ section.settings.closing_title }}</h2><p class="scale-flow__section-copy">{{ section.settings.closing_text }}</p><a class="scale-flow__cta" href="{{ section.settings.closing_cta_link | default: '#' }}">{{ section.settings.closing_cta_label }}</a></div>

  <div class="scale-flow__section scale-flow__glass-panel"><h2>{{ section.settings.log_title }}</h2><div class="scale-flow__log-grid">{% for block in section.blocks %}{% if block.type == 'log_step' %}<article class="scale-flow__card" {{ block.shopify_attributes }}><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p></article>{% endif %}{% endfor %}</div></div>

  <div class="scale-flow__section scale-flow__glass-panel scale-flow__newsletter"><h2>{{ section.settings.newsletter_title }}</h2><p class="scale-flow__section-copy">{{ section.settings.newsletter_text }}</p>{% form 'customer', class: 'scale-flow__newsletter-form' %}<input type="hidden" name="contact[tags]" value="newsletter"><input type="email" name="contact[email]" placeholder="{{ section.settings.newsletter_placeholder }}" required><button class="scale-flow__cta" type="submit">{{ section.settings.newsletter_button }}</button>{% endform %}</div>
</section>

{% stylesheet %}
  .scale-flow{--sf-bg:#050505;--sf-cyan:#00f5ff;--sf-indigo:#6366f1;--sf-title:#fff;--sf-body:#94a3b8;position:relative;overflow:clip;background:radial-gradient(circle at 20% 20%,rgb(0 245 255 / 10%),transparent 40%),radial-gradient(circle at 80% 10%,rgb(99 102 241 / 16%),transparent 30%),var(--sf-bg);color:var(--sf-body);padding-inline:clamp(1rem,4vw,3rem)}.scale-flow__bg-texture{position:absolute;inset:0;background-image:linear-gradient(rgb(255 255 255 / 2%) 1px,transparent 1px),linear-gradient(90deg,rgb(255 255 255 / 2%) 1px,transparent 1px);background-size:44px 44px;opacity:.2;pointer-events:none;z-index:0}.scale-flow__section,.scale-flow__hero{position:relative;z-index:1;max-width:1240px;margin-inline:auto;margin-block:0 clamp(2rem,6vw,4rem)}.scale-flow__glass-panel{border:1px solid rgb(255 255 255 / 14%);background:linear-gradient(140deg,rgb(30 41 59 / 70%),rgb(30 41 59 / 40%));backdrop-filter:blur(18px);border-radius:28px;box-shadow:inset 0 1px 0 rgb(255 255 255 / 24%),0 24px 60px rgb(0 0 0 / 42%);padding:clamp(1.2rem,3vw,2.5rem)}.scale-flow__hero{min-height:min(78svh,820px);display:grid;place-items:center;text-align:center;isolation:isolate}.scale-flow h1,.scale-flow h2,.scale-flow h3{color:var(--sf-title);font-family:Outfit,Syne,"Segoe UI",sans-serif;letter-spacing:.02em}.scale-flow h1{margin:.2rem 0;font-size:clamp(2rem,5vw,4rem)}.scale-flow__hero-title-alt{color:transparent;background:linear-gradient(120deg,var(--sf-cyan),var(--sf-indigo));-webkit-background-clip:text;background-clip:text}.scale-flow__hero-copy,.scale-flow__section-copy{font-family:Inter,Montserrat,"Segoe UI",sans-serif;line-height:1.6;max-width:72ch;margin-inline:auto}.scale-flow__badge{display:inline-flex;border-radius:999px;border:1px solid rgb(0 245 255 / 40%);background:rgb(0 245 255 / 12%);padding:.38rem 1rem;color:#d8fbff;text-transform:uppercase;letter-spacing:.12em;font-size:.74rem;font-weight:700}.scale-flow__hero-ctas{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap;margin-top:1rem}.scale-flow__cta{display:inline-flex;align-items:center;justify-content:center;padding:.9rem 1.65rem;border-radius:14px;color:#05121f;font-weight:700;text-decoration:none;background:linear-gradient(120deg,var(--sf-cyan),var(--sf-indigo));box-shadow:0 0 20px rgb(0 245 255 / 35%)}.scale-flow__cta--ghost{background:transparent;color:#fff;border:1px solid rgb(255 255 255 / 20%);box-shadow:none}.scale-flow__trust-row{margin-top:1.2rem;display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap}.scale-flow__trust-row span{border:1px solid rgb(255 255 255 / 15%);border-radius:12px;padding:.42rem .75rem;background:rgb(15 23 42 / 45%)}.scale-flow__section-heading{text-align:center;margin-bottom:1.2rem}.scale-flow__section-heading p:first-child{margin:0;color:var(--sf-cyan);font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;font-weight:700}.scale-flow h2{margin:.5rem 0 .7rem;font-size:clamp(1.6rem,3.5vw,2.6rem)}.scale-flow__lab-grid,.scale-flow__streams-grid,.scale-flow__product-grid,.scale-flow__proof-grid,.scale-flow__stats-grid,.scale-flow__log-grid{display:grid;gap:1rem}.scale-flow__lab-grid,.scale-flow__streams-grid,.scale-flow__product-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.scale-flow__proof-grid,.scale-flow__stats-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.scale-flow__log-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.scale-flow__card{border:1px solid rgb(255 255 255 / 14%);border-radius:18px;background:rgb(15 23 42 / 45%);padding:1rem}.scale-flow__lab-icon{width:44px;height:44px;border-radius:14px;display:grid;place-items:center;margin-bottom:.75rem;background:rgb(0 245 255 / 15%);color:var(--sf-cyan)}.scale-flow__stream-label{color:var(--sf-cyan);letter-spacing:.08em;text-transform:uppercase;font-size:.74rem;font-weight:700}.scale-flow__stream-link{display:inline-block;margin-top:.5rem;color:var(--sf-cyan);font-weight:700;text-decoration:none}.scale-flow__product-link{text-decoration:none;color:inherit;display:block}.scale-flow__product-media{border-radius:14px;overflow:hidden;margin-bottom:.7rem;aspect-ratio:16/11;background:rgb(0 0 0 / 20%)}.scale-flow__product-image,.scale-flow__product-placeholder svg{width:100%;height:100%;object-fit:cover;display:block}.scale-flow__price{color:var(--sf-cyan);font-weight:700}.scale-flow__stat-card{text-align:center}.scale-flow__stat-card h3{color:var(--sf-cyan)}.scale-flow__faq-list{display:grid;gap:.7rem}.scale-flow__faq-item{border:1px solid rgb(255 255 255 / 12%);border-radius:14px;padding:.85rem .95rem;background:rgb(15 23 42 / 42%)}.scale-flow__faq-item summary{list-style:none;display:flex;gap:.7rem;align-items:center;color:#fff;cursor:pointer;font-weight:600}.scale-flow__faq-item summary::-webkit-details-marker{display:none}.scale-flow__faq-dot{width:10px;height:10px;border-radius:999px;background:var(--sf-cyan);box-shadow:0 0 14px rgb(0 245 255 / 62%)}.scale-flow__faq-contact{text-align:center;margin-top:1rem}.scale-flow__faq-contact a{color:var(--sf-cyan);text-decoration:none;font-weight:700}.scale-flow__closing,.scale-flow__newsletter{text-align:center}.scale-flow__newsletter-form{display:flex;justify-content:center;gap:.7rem;flex-wrap:wrap;margin-top:1rem}.scale-flow__newsletter-form input{min-width:min(100%,360px);min-height:46px;border-radius:12px;border:1px solid rgb(255 255 255 / 20%);background:rgb(15 23 42 / 55%);color:#fff;padding:.65rem .75rem}.scale-flow__floating-layer{position:absolute;inset:0;pointer-events:none;z-index:-1}.scale-flow__shape{position:absolute;display:block;border-radius:999px;transform:translate3d(0,0,0);animation:sf-float 10s ease-in-out infinite;background:linear-gradient(160deg,rgb(0 245 255 / 36%),rgb(99 102 241 / 38%));border:1px solid rgb(255 255 255 / 25%)}.scale-flow__shape--sphere{width:clamp(90px,10vw,150px);height:clamp(90px,10vw,150px);top:12%;left:6%}.scale-flow__shape--cube{width:clamp(72px,8vw,122px);height:clamp(72px,8vw,122px);border-radius:24px;right:10%;top:18%}.scale-flow__shape--thread{width:220px;height:80px;border-radius:999px;bottom:12%;right:18%;transform:rotate(-12deg)}.scale-flow__shape--small{width:58px;height:58px;top:67%;left:19%}.scale-flow__shape--wide{width:min(32vw,320px);left:9%;top:9%}@keyframes sf-float{0%{transform:translate3d(0,0,0)}50%{transform:translate3d(0,-14px,0)}100%{transform:translate3d(0,0,0)}}@media screen and (max-width:990px){.scale-flow__lab-grid,.scale-flow__streams-grid,.scale-flow__product-grid,.scale-flow__proof-grid,.scale-flow__stats-grid,.scale-flow__log-grid{grid-template-columns:1fr 1fr}}@media screen and (max-width:740px){.scale-flow__lab-grid,.scale-flow__streams-grid,.scale-flow__product-grid,.scale-flow__proof-grid,.scale-flow__stats-grid,.scale-flow__log-grid{grid-template-columns:1fr}.scale-flow__shape--thread,.scale-flow__shape--wide{display:none}}
{% endstylesheet %}

<script>
  (() => {
    const root = document.getElementById('ScaleFlow-{{ section.id }}');
    if (!root || root.dataset.flowInit === 'true') return;
    root.dataset.flowInit = 'true';
    const shapes = Array.from(root.querySelectorAll('.scale-flow__shape[data-speed]'));
    const pointer = { x: 0, y: 0 };
    const state = { x: 0, y: 0 };
    root.addEventListener('pointermove', (event) => {
      const bounds = root.getBoundingClientRect();
      pointer.x = ((event.clientX - bounds.left) / bounds.width - 0.5) * 2;
      pointer.y = ((event.clientY - bounds.top) / bounds.height - 0.5) * 2;
    }, { passive: true });
    window.addEventListener('scroll', () => {
      const bounds = root.getBoundingClientRect();
      pointer.y = Math.max(-1, Math.min(1, -bounds.top / window.innerHeight)) * 0.8;
    }, { passive: true });
    const animate = () => {
      state.x += (pointer.x - state.x) * 0.06;
      state.y += (pointer.y - state.y) * 0.06;
      shapes.forEach((shape) => {
        const speed = Number(shape.dataset.speed || 0.02);
        shape.style.transform = `translate3d(${state.x * (speed * 100) * 8}px, ${state.y * (speed * 100) * 8}px, 0)`;
      });
      window.requestAnimationFrame(animate);
    };
    window.requestAnimationFrame(animate);
  })();
</script>

{% schema %}
{
  "name": "Scale Flow Home",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    { "type": "text", "id": "hero_badge", "label": "Hero badge", "default": "Toolkits de Crecimiento con IA" },
    { "type": "text", "id": "hero_title", "label": "Hero titulo 1", "default": "Escala Mas Inteligente." },
    { "type": "text", "id": "hero_title_alt", "label": "Hero titulo 2", "default": "Fluye Mas Lejos." },
    { "type": "textarea", "id": "hero_text", "label": "Hero texto", "default": "Accede a guias verificadas, toolkits y blueprints de automatizacion para escalar tu negocio." },
    { "type": "text", "id": "hero_cta_label", "label": "CTA primario", "default": "Explorar la Biblioteca" },
    { "type": "url", "id": "hero_cta_link", "label": "Link CTA primario" },
    { "type": "text", "id": "hero_secondary_cta_label", "label": "CTA secundario", "default": "Ver Como Funciona" },
    { "type": "url", "id": "hero_secondary_cta_link", "label": "Link CTA secundario" },
    { "type": "text", "id": "trust_1", "label": "Trust 1", "default": "Verificado por expertos" },
    { "type": "text", "id": "trust_2", "label": "Trust 2", "default": "Descarga instantanea" },
    { "type": "text", "id": "trust_3", "label": "Trust 3", "default": "Mas de 10,000 fundadores" },
    { "type": "text", "id": "lab_kicker", "label": "Lab kicker", "default": "El Laboratorio" },
    { "type": "text", "id": "lab_title", "label": "Lab titulo", "default": "Impulsado por Inteligencia Hibrida" },
    { "type": "textarea", "id": "lab_text", "label": "Lab texto", "default": "Combinamos el juicio de expertos humanos con la velocidad de la IA." },
    { "type": "text", "id": "featured_kicker", "label": "Streams kicker", "default": "Streams" },
    { "type": "text", "id": "featured_title", "label": "Streams titulo", "default": "Elige Tu Stream" },
