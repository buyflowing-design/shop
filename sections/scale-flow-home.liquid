{% liquid
  assign featured_collection = section.settings.featured_collection
%}

<section id="ScaleFlow-{{ section.id }}" class="sf-home spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="sf-home__bg"></div>

  <div class="sf-home__hero">
    <div class="sf-home__orb sf-home__orb--tl"></div>
    <div class="sf-home__orb sf-home__orb--tr"></div>
    <div class="sf-home__orb sf-home__orb--br"></div>
    <div class="sf-home__shape"></div>

    <h1 class="sf-home__title">{{ section.settings.hero_title }}</h1>
    <h1 class="sf-home__title sf-home__title--gradient">{{ section.settings.hero_title_alt }}</h1>
    <p class="sf-home__subtitle">{{ section.settings.hero_text }}</p>

    <div class="sf-home__hero-ctas">
      <a class="sf-home__cta sf-home__cta--primary" href="{{ section.settings.hero_cta_link | default: '#' }}">{{ section.settings.hero_cta_label }}</a>
      <a class="sf-home__cta sf-home__cta--ghost" href="{{ section.settings.hero_secondary_cta_link | default: '#' }}">{{ section.settings.hero_secondary_cta_label }}</a>
    </div>

    <div class="sf-home__trust">
      <span>{{ section.settings.trust_1 }}</span>
      <span>{{ section.settings.trust_2 }}</span>
      <span>{{ section.settings.trust_3 }}</span>
    </div>
  </div>

  <div class="sf-home__section sf-home__section--lab">
    <h2>{{ section.settings.lab_title }}</h2>
    <p class="sf-home__section-subtitle">{{ section.settings.lab_text }}</p>

    <div class="sf-home__lab-grid sf-home__panel">
      {% for block in section.blocks %}
        {% if block.type == 'lab_item' %}
          <article class="sf-home__item-card" {{ block.shopify_attributes }}>
            <div class="sf-home__icon">{{ block.settings.icon }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sf-home__section">
    <h2>{{ section.settings.streams_title }}</h2>
    <p class="sf-home__section-subtitle">{{ section.settings.streams_text }}</p>

    <div class="sf-home__streams-grid">
      {% for block in section.blocks %}
        {% if block.type == 'stream_item' %}
          {% assign stream_title_key = block.settings.title | downcase %}
          <article class="sf-home__stream-card sf-home__panel" {{ block.shopify_attributes }}>
            <div class="sf-home__icon sf-home__icon--stream" aria-hidden="true">
              {% if stream_title_key contains 'creative' %}
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M5 19L19 5" />
                  <path d="M7.5 7.5L9.2 9.2" />
                  <path d="M14.8 14.8L16.5 16.5" />
                  <path d="M4.5 12H2.8" />
                  <path d="M12 4.5V2.8" />
                  <path d="M6.7 17.3L5.5 18.5" />
                  <path d="M17.3 6.7L18.5 5.5" />
                </svg>
              {% elsif stream_title_key contains 'sales' %}
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M4 16L10 10L13.5 13.5L20 7" />
                  <path d="M16.6 7H20V10.4" />
                  <path d="M5 20H19" />
                </svg>
              {% elsif stream_title_key contains 'biz' %}
                <svg viewBox="0 0 24 24" fill="none">
                  <rect x="4" y="4" width="6" height="6" rx="1.5" />
                  <rect x="14" y="4" width="6" height="6" rx="1.5" />
                  <rect x="9" y="14" width="6" height="6" rx="1.5" />
                  <path d="M7 10V12.2C7 13.2 7.8 14 8.8 14H12" />
                  <path d="M17 10V12.2C17 13.2 16.2 14 15.2 14H12" />
                </svg>
              {% else %}
                {{ block.settings.icon }}
              {% endif %}
            </div>
            <p class="sf-home__stream-label">{{ block.settings.label }}</p>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
            <a href="{{ block.settings.link | default: '#' }}" class="sf-home__stream-link">{{ section.settings.stream_cta_label }}</a>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sf-home__section sf-home__section--proof">
    <h2>{{ section.settings.proof_title }}</h2>
    <p class="sf-home__section-subtitle">{{ section.settings.proof_text }}</p>
    <div class="sf-home__proof-grid">
      {% for block in section.blocks %}
        {% if block.type == 'proof_item' %}
          <article class="sf-home__item-card sf-home__panel sf-home__proof-card" {{ block.shopify_attributes }}>
            <div class="sf-home__icon">{{ block.settings.icon }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
    <div class="sf-home__proof-stats">
      <article class="sf-home__proof-stat">
        <h3>{{ section.settings.proof_stat_1_value }}</h3>
        <p>{{ section.settings.proof_stat_1_label }}</p>
      </article>
      <article class="sf-home__proof-stat">
        <h3>{{ section.settings.proof_stat_2_value }}</h3>
        <p>{{ section.settings.proof_stat_2_label }}</p>
      </article>
      <article class="sf-home__proof-stat">
        <h3>{{ section.settings.proof_stat_3_value }}</h3>
        <p>{{ section.settings.proof_stat_3_label }}</p>
      </article>
      <article class="sf-home__proof-stat">
        <h3>{{ section.settings.proof_stat_4_value }}</h3>
        <p>{{ section.settings.proof_stat_4_label }}</p>
      </article>
    </div>
  </div>

  <div class="sf-home__section">
    <h2>{{ section.settings.faq_title }}</h2>
    <p class="sf-home__section-subtitle">{{ section.settings.faq_text }}</p>
    <div class="sf-home__faq-list">
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          <details class="sf-home__faq-item sf-home__panel" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <p>{{ block.settings.answer }}</p>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sf-home__section sf-home__closing">
    <h2>{{ section.settings.closing_title }}</h2>
    <p class="sf-home__section-subtitle">{{ section.settings.closing_text }}</p>
    <a class="sf-home__cta sf-home__cta--primary" href="{{ section.settings.closing_cta_link | default: '#' }}">{{ section.settings.closing_cta_label }}</a>
    <div class="sf-home__trust">
      <span>{{ section.settings.close_trust_1 }}</span>
      <span>{{ section.settings.close_trust_2 }}</span>
      <span>{{ section.settings.close_trust_3 }}</span>
    </div>
  </div>

  {% if featured_collection != blank %}
    <div class="sf-home__section">
      <div class="sf-home__streams-grid">
        {% for product in featured_collection.products limit: 3 %}
          <article class="sf-home__stream-card sf-home__panel">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 700 | image_tag: class: 'sf-home__product-image', loading: 'lazy', alt: product.title }}
              {% endif %}
              <h3>{{ product.title }}</h3>
            </a>
          </article>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .sf-home {
    --bg: #050505;
    --cyan: #00f5ff;
    --indigo: #6366f1;
    --text: #ffffff;
    --muted: #9ca3af;
    color: var(--text);
    background: var(--bg);
    padding-inline: 1.25rem;
    position: relative;
    overflow: hidden;
  }

  .sf-home__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(900px 520px at 12% 12%, rgb(0 245 255 / 22%), transparent 55%),
      radial-gradient(900px 600px at 86% 70%, rgb(99 102 241 / 23%), transparent 58%);
    pointer-events: none;
  }

  .sf-home__panel {
    border: 1px solid rgb(255 255 255 / 12%);
    border-radius: 28px;
    background: linear-gradient(150deg, rgb(15 23 42 / 72%), rgb(15 23 42 / 54%));
    backdrop-filter: blur(14px);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 12%);
  }

  .sf-home__hero,
  .sf-home__section {
    max-width: 1120px;
    margin: 0 auto 4rem;
    position: relative;
    z-index: 1;
    min-height: calc(100svh - 110px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .sf-home__hero {
    text-align: center;
    padding: 8.8rem 2.2rem 6.4rem;
    min-height: calc(100svh - 110px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .sf-home__title {
    margin: 0;
    font: 800 clamp(2.45rem, 7.5vw, 5.1rem) / 1.02 Outfit, Inter, sans-serif;
  }

  .sf-home__title--gradient {
    background: linear-gradient(90deg, var(--cyan), var(--indigo));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .sf-home__subtitle,
  .sf-home__section-subtitle {
    margin: 1.25rem auto 0;
    max-width: 760px;
    font-size: clamp(1rem, 2.1vw, 1.95rem);
    color: var(--muted);
    line-height: 1.52;
  }

  .sf-home__hero-ctas {
    margin-top: 1.8rem;
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .sf-home__cta {
    min-height: 56px;
    padding: 0.92rem 1.8rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-weight: 700;
  }

  .sf-home__cta--primary {
    color: #031016;
    background: linear-gradient(90deg, var(--cyan), var(--indigo));
    box-shadow: 0 0 24px rgb(0 245 255 / 24%);
  }

  .sf-home__cta--ghost {
    color: #dbe4ef;
    border: 1px solid rgb(255 255 255 / 22%);
    background: rgb(10 15 30 / 70%);
  }

  .sf-home__trust {
    margin-top: 1.8rem;
    display: flex;
    justify-content: center;
    gap: 1.3rem;
    flex-wrap: wrap;
    color: #b4c0d2;
    font-size: 0.96rem;
  }

  .sf-home h2 {
    margin: 0 auto;
    max-width: 900px;
    text-align: center;
    font: 800 clamp(2rem, 6.4vw, 4.45rem) / 1.08 Outfit, Inter, sans-serif;
  }

  .sf-home__section--lab {
    padding-top: 2.1rem;
  }

  .sf-home__section--lab h2 {
    max-width: 780px;
    font: 800 clamp(2.55rem, 6.4vw, 4.85rem) / 1.04 Outfit, Inter, sans-serif;
    letter-spacing: -0.015em;
  }

  .sf-home__section--lab .sf-home__section-subtitle {
    margin-top: 1.5rem;
    max-width: 820px;
    color: #9fb0c8;
    font-size: clamp(1.08rem, 2.1vw, 1.9rem);
    line-height: 1.58;
  }

  .sf-home__lab-grid {
    margin-top: 2.55rem;
    padding: 2.15rem 2.2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.25rem;
    border-radius: 30px;
    border: 1px solid rgb(255 255 255 / 16%);
    background: linear-gradient(145deg, rgb(22 35 62 / 76%), rgb(18 28 51 / 68%));
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 12%), 0 22px 48px rgb(0 0 0 / 24%);
    backdrop-filter: blur(18px);
  }

  .sf-home__section--lab .sf-home__item-card {
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .sf-home__icon {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    background: linear-gradient(145deg, rgb(11 26 50 / 88%), rgb(14 31 59 / 74%));
    border: 1px solid rgb(0 245 255 / 38%);
    color: var(--cyan);
    font-weight: 700;
    margin-bottom: 1.35rem;
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 10%), 0 0 28px rgb(0 245 255 / 28%);
  }

  .sf-home__icon--stream svg {
    width: 28px;
    height: 28px;
    stroke: #6defff;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 0 10px rgb(0 245 255 / 30%));
  }

  .sf-home__item-card h3,
  .sf-home__stream-card h3 {
    margin: 0;
    font: 700 clamp(1.3rem, 3.3vw, 2rem) / 1.2 Outfit, Inter, sans-serif;
    color: #ffffff;
  }

  .sf-home__section--lab .sf-home__item-card h3 {
    font: 700 clamp(1.42rem, 2.9vw, 2.1rem) / 1.2 Outfit, Inter, sans-serif;
  }

  .sf-home__item-card p,
  .sf-home__stream-card p {
    margin: 0.7rem 0 0;
    color: #9fb0c6;
    line-height: 1.55;
  }

  .sf-home__section--lab .sf-home__item-card p {
    margin-top: 0.9rem;
    color: #9fb0c8;
    font-size: clamp(1.02rem, 1.8vw, 1.25rem);
    line-height: 1.6;
  }

  .sf-home__streams-grid a,
  .sf-home__streams-grid .sf-home__stream-link {
    color: #00f5ff;
  }

  .sf-home__streams-grid,
  .sf-home__proof-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .sf-home__proof-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.45rem;
  }

  .sf-home__section--proof {
    align-items: center;
  }

  .sf-home__section--proof h2 {
    max-width: 860px;
    font: 800 clamp(2.7rem, 6.8vw, 5rem) / 1.06 Outfit, Inter, sans-serif;
    letter-spacing: -0.015em;
  }

  .sf-home__section--proof .sf-home__section-subtitle {
    margin-top: 1.45rem;
    max-width: 900px;
    color: #96a9c4;
    font-size: clamp(1.08rem, 2vw, 1.72rem);
    line-height: 1.56;
  }

  .sf-home__proof-card {
    min-height: 330px;
    padding: 1.75rem 1.5rem 1.55rem;
    border-radius: 24px;
    border: 1px solid rgb(255 255 255 / 13%);
    background: linear-gradient(160deg, rgb(17 28 49 / 80%), rgb(14 25 45 / 64%));
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 12%);
  }

  .sf-home__proof-card .sf-home__icon {
    width: 58px;
    height: 58px;
    border-radius: 16px;
    margin-bottom: 1.25rem;
  }

  .sf-home__proof-card h3 {
    font: 700 clamp(1.28rem, 2.1vw, 1.9rem) / 1.25 Outfit, Inter, sans-serif;
  }

  .sf-home__proof-card p {
    margin-top: 0.85rem;
    color: #9aacc4;
    font-size: clamp(1rem, 1.35vw, 1.15rem);
    line-height: 1.52;
  }

  .sf-home__proof-stats {
    margin-top: 1.9rem;
    padding-top: 1.9rem;
    width: 100%;
    border-top: 1px solid rgb(0 245 255 / 22%);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .sf-home__proof-stat {
    text-align: center;
  }

  .sf-home__proof-stat h3 {
    margin: 0;
    font: 800 clamp(2.35rem, 4.2vw, 4rem) / 1 Outfit, Inter, sans-serif;
    color: #86f7ff;
    letter-spacing: -0.02em;
    text-shadow: 0 0 20px rgb(0 245 255 / 24%);
  }

  .sf-home__proof-stat p {
    margin: 0.48rem 0 0;
    font-size: 0.96rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #a7b9d1;
  }

  .sf-home__stream-card {
    padding: 1.6rem;
  }

  .sf-home__stream-label {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cyan);
    font-weight: 700;
  }

  .sf-home__stream-link {
    margin-top: 1rem;
    display: inline-flex;
    color: var(--cyan);
    text-decoration: none;
    font-weight: 700;
  }

  .sf-home__faq-list {
    margin-top: 1.8rem;
    display: grid;
    gap: 0.9rem;
  }

  .sf-home__faq-item {
    padding: 1.2rem 1.4rem;
    border-radius: 18px;
  }

  .sf-home__faq-item summary {
    cursor: pointer;
    font: 700 clamp(1.06rem, 2.2vw, 1.4rem) / 1.3 Outfit, Inter, sans-serif;
    list-style: none;
  }

  .sf-home__faq-item summary::-webkit-details-marker {
    display: none;
  }

  .sf-home__faq-item p {
    margin: 0.8rem 0 0;
    color: #a8b8cd;
  }

  .sf-home__closing {
    text-align: center;
    padding: 3rem 2rem 2.5rem;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .sf-home__orb,
  .sf-home__shape {
    position: absolute;
    pointer-events: none;
    filter: blur(0.2px);
  }

  .sf-home__orb {
    border-radius: 999px;
    background: linear-gradient(135deg, rgb(0 245 255 / 25%), rgb(99 102 241 / 25%));
    box-shadow: 0 0 44px rgb(0 245 255 / 24%);
  }

  .sf-home__orb--tl {
    width: 86px;
    height: 86px;
    left: 11%;
    top: 20%;
  }

  .sf-home__orb--tr {
    width: 160px;
    height: 160px;
    right: 8%;
    top: 13%;
  }

  .sf-home__orb--br {
    width: 230px;
    height: 230px;
    right: 10%;
    bottom: 10%;
    opacity: 0.35;
  }

  .sf-home__shape {
    width: 150px;
    height: 150px;
    border-radius: 26px;
    left: 8%;
    bottom: 8%;
    border: 1px solid rgb(99 102 241 / 35%);
    background: linear-gradient(135deg, rgb(0 245 255 / 10%), rgb(99 102 241 / 16%));
    transform: rotate(27deg);
  }

  .sf-home__product-image {
    width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 0.8rem;
  }

  @media screen and (max-width: 1024px) {
    .sf-home__proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sf-home__proof-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: 1.45rem;
    }
  }

  @media screen and (max-width: 760px) {
    .sf-home__hero {
      min-height: calc(100svh - 78px);
      padding-top: 7.4rem;
      padding-bottom: 4.6rem;
      justify-content: center;
    }

    .sf-home__section {
      min-height: calc(100svh - 78px);
      justify-content: center;
    }

    .sf-home__lab-grid,
    .sf-home__streams-grid,
    .sf-home__proof-grid {
      grid-template-columns: 1fr;
    }

    .sf-home__proof-card {
      min-height: auto;
    }

    .sf-home__proof-stats {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .sf-home__item-card {
      border-right: 1px solid rgb(255 255 255 / 12%);
    }

    .sf-home__lab-grid {
      padding: 1.45rem 1.15rem;
      gap: 1.3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Scale Flow Home",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    { "type": "text", "id": "hero_badge", "label": "Badge hero", "default": "TOOLKITS DE CRECIMIENTO CON IA" },
    { "type": "text", "id": "hero_title", "label": "Hero linea 1", "default": "Escala Mas Inteligente." },
    { "type": "text", "id": "hero_title_alt", "label": "Hero linea 2", "default": "Fluye Mas Lejos." },
    { "type": "textarea", "id": "hero_text", "label": "Hero texto", "default": "Guias verificadas por expertos, toolkits y estrategias potenciadas por IA para hacer crecer tu negocio mas rapido." },
    { "type": "text", "id": "hero_cta_label", "label": "CTA principal", "default": "Explorar la Biblioteca" },
    { "type": "url", "id": "hero_cta_link", "label": "Link CTA principal" },
    { "type": "text", "id": "hero_secondary_cta_label", "label": "CTA secundario", "default": "Ver Como Funciona" },
    { "type": "url", "id": "hero_secondary_cta_link", "label": "Link CTA secundario" },
    { "type": "text", "id": "trust_1", "label": "Trust 1", "default": "Verificado por expertos" },
    { "type": "text", "id": "trust_2", "label": "Trust 2", "default": "Descarga instantanea" },
    { "type": "text", "id": "trust_3", "label": "Trust 3", "default": "Mas de 10,000 fundadores" },
    { "type": "text", "id": "lab_kicker", "label": "Kicker laboratorio", "default": "EL LABORATORIO" },
    { "type": "text", "id": "lab_title", "label": "Titulo laboratorio", "default": "Impulsado por Inteligencia Hibrida" },
    { "type": "textarea", "id": "lab_text", "label": "Texto laboratorio", "default": "Combinamos el juicio irremplazable de expertos humanos con la velocidad inigualable de la IA para que obtengas estrategias que realmente funcionan." },
    { "type": "text", "id": "streams_kicker", "label": "Kicker streams", "default": "STREAMS" },
    { "type": "text", "id": "streams_title", "label": "Titulo streams", "default": "Elige Tu Stream" },
    { "type": "textarea", "id": "streams_text", "label": "Texto streams", "default": "Cada toolkit esta construido para un unico objetivo: crecimiento medible." },
    { "type": "text", "id": "stream_cta_label", "label": "Texto CTA stream", "default": "Explorar Stream" },
    { "type": "collection", "id": "featured_collection", "label": "Coleccion destacada opcional" },
    { "type": "text", "id": "proof_kicker", "label": "Kicker proof", "default": "POR QUE SCALE FLOW" },
    { "type": "text", "id": "proof_title", "label": "Titulo proof", "default": "Por Que los Fundadores Eligen Scale Flow" },
