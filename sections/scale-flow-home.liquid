    { "type": "text", "id": "faq_title", "label": "FAQ titulo", "default": "Todo Lo Que Necesitas Saber" },
    { "type": "textarea", "id": "faq_text", "label": "FAQ texto", "default": "Sin rodeos - solo respuestas." },
    { "type": "text", "id": "faq_contact_text", "label": "FAQ contacto texto", "default": "¿Aun tienes preguntas?" },
