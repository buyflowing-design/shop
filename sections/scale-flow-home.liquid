        "lab_2": { "type": "lab_item", "settings": { "icon": "⚡", "title": "Eficiencia con IA", "text": "Cada framework optimizado y testado con IA para el maximo rendimiento." } },
        "lab_3": { "type": "lab_item", "settings": { "icon": "↻", "title": "Flujo Accionable", "text": "Blueprints paso a paso que puedes implementar de inmediato." } },
