{% liquid
  assign current_variant = product.selected_or_first_available_variant
%}

<section id="ScaleFlowProduct-{{ section.id }}" class="sfp spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="sfp__bg"></div>

  <div class="sfp__hero">
    <div class="sfp__hero-media sfp__glass">
      <div class="sfp__hero-media-inner">
        {% if product.featured_media %}
          {{
            product.featured_media.preview_image
            | image_url: width: 1200
            | image_tag:
              class: 'sfp__hero-image',
              widths: '480, 720, 960, 1200',
              loading: 'eager',
              fetchpriority: 'high',
              alt: product.title
          }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'sfp__hero-placeholder' }}
        {% endif %}
      </div>
    </div>

    <div class="sfp__hero-copy">
      {% if section.settings.kicker != blank %}<p class="sfp__chip">{{ section.settings.kicker }}</p>{% endif %}
      <h1>{{ product.title }}</h1>
      <p class="sfp__desc">{{ product.description | strip_html | truncatewords: 30 }}</p>

      <div class="sfp__rating-line">
        <span class="sfp__stars">★★★★★</span>
        <strong>4.9</strong>
        <span>247 reseñas</span>
      </div>

      <div class="sfp__price-line">
        <span class="sfp__price" data-sfp-price>{{ current_variant.price | money }}</span>
        <span class="sfp__compare">{{ section.settings.compare_price_text }}</span>
      </div>

      <ul class="sfp__benefits">
        {% if section.settings.benefit_1 != blank %}<li>{{ section.settings.benefit_1 }}</li>{% endif %}
        {% if section.settings.benefit_2 != blank %}<li>{{ section.settings.benefit_2 }}</li>{% endif %}
        {% if section.settings.benefit_3 != blank %}<li>{{ section.settings.benefit_3 }}</li>{% endif %}
      </ul>

      {% form 'product', product, class: 'sfp__form' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-sfp-variant-id>

        {% if product.has_only_default_variant == false %}
          <select class="sfp__select" data-sfp-variant-select>
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" {% if variant.id == current_variant.id %}selected{% endif %}>
                {{ variant.title }}{% unless variant.available %} - Agotado{% endunless %}
              </option>
            {% endfor %}
          </select>
        {% endif %}

        <button class="sfp__cta" type="submit" {% unless current_variant.available %}disabled{% endunless %}>
          {{ section.settings.cta_text }} - {{ current_variant.price | money }}
        </button>
      {% endform %}

      <p class="sfp__security">{{ section.settings.security_text }}</p>
    </div>
  </div>

  <div class="sfp__ticker sfp__glass">
    <p>{{ section.settings.ticker_text }}</p>
  </div>

  <div class="sfp__section">
    {% if section.settings.extras_kicker != blank %}<p class="sfp__chip">{{ section.settings.extras_kicker }}</p>{% endif %}
    <h2>{{ section.settings.extras_title }}</h2>
    <p class="sfp__section-sub">{{ section.settings.extras_text }}</p>
    <div class="sfp__features-grid">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <article class="sfp__feature-card sfp__glass" {{ block.shopify_attributes }}>
            <p class="sfp__emoji">{{ block.settings.emoji }}</p>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sfp__section">
    {% if section.settings.reviews_kicker != blank %}<p class="sfp__chip">{{ section.settings.reviews_kicker }}</p>{% endif %}
    <h2>{{ section.settings.reviews_title }}</h2>
    <div class="sfp__reviews-score"><span class="sfp__score">4.9</span><span class="sfp__stars">★★★★★</span><span>Basado en 247 opiniones</span></div>
    <div class="sfp__reviews-grid">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <article class="sfp__review-card sfp__glass" {{ block.shopify_attributes }}>
            <div class="sfp__review-top">
              <div class="sfp__avatar">{{ block.settings.author | slice: 0, 1 }}{{ block.settings.author | split: ' ' | last | slice: 0, 1 }}</div>
              <div>
                <h3>{{ block.settings.author }}</h3>
                <p class="sfp__location">{{ block.settings.location }}</p>
              </div>
            </div>
            <div class="sfp__review-meta">★★★★★ <span>{{ block.settings.when }}</span></div>
            <p class="sfp__review-text">{{ block.settings.quote }}</p>
            <p class="sfp__verified">{{ block.settings.verification }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sfp__section">
    {% if section.settings.numbers_kicker != blank %}<p class="sfp__chip">{{ section.settings.numbers_kicker }}</p>{% endif %}
    <h2>{{ section.settings.numbers_title }}</h2>
    <div class="sfp__numbers-grid">
      {% for block in section.blocks %}
        {% if block.type == 'number' %}
          <article class="sfp__number-card sfp__glass" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.metric }}</h3>
            <p class="sfp__number-label">{{ block.settings.label }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sfp__tools sfp__glass">
    {% if section.settings.tools_kicker != blank %}<p class="sfp__tools-title">{{ section.settings.tools_kicker }}</p>{% endif %}
    <div class="sfp__tools-row">
      {% for block in section.blocks %}
        {% if block.type == 'tool' %}
          <span class="sfp__tool-pill" {{ block.shopify_attributes }}>{{ block.settings.name }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sfp__section">
    {% if section.settings.faq_kicker != blank %}<p class="sfp__chip">{{ section.settings.faq_kicker }}</p>{% endif %}
    <h2>{{ section.settings.faq_title }}</h2>
    <p class="sfp__section-sub">Todo lo que necesitas saber antes de empezar.</p>
    <div class="sfp__faq-list">
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}
          <details class="sfp__faq-item sfp__glass" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <p>{{ block.settings.answer }}</p>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sfp__final">
    {% if section.settings.offer_kicker != blank %}<p class="sfp__chip">{{ section.settings.offer_kicker }}</p>{% endif %}
    <h2>{{ section.settings.final_title }}</h2>
    <p class="sfp__section-sub">{{ section.settings.final_text }}</p>
    <div class="sfp__offer-price">
      <span class="sfp__old">{{ section.settings.offer_old_price }}</span>
      <span class="sfp__new">{{ section.settings.offer_new_price }}</span>
      <span class="sfp__save">{{ section.settings.offer_save }}</span>
    </div>
    <a href="{{ product.url }}?variant={{ current_variant.id }}" class="sfp__cta sfp__cta--final">{{ section.settings.final_cta }}</a>
    <div class="sfp__final-trust">
      <span>Pago Seguro SSL</span><span>Acceso Inmediato</span><span>30 Días de Garantía</span>
    </div>
    <p class="sfp__urgency">{{ section.settings.offer_urgency }}</p>
  </div>
</section>

{% stylesheet %}
  .sfp {
    --bg: #050505;
    --cyan: #00f5ff;
    --indigo: #6366f1;
    --text: #fff;
    --muted: #95a6be;
    background: var(--bg);
    color: var(--text);
    padding-inline: clamp(0.9rem, 2.5vw, 2rem);
    position: relative;
    overflow: clip;
  }

  .sfp__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(800px 500px at 6% 8%, rgb(0 245 255 / 18%), transparent 62%),
      radial-gradient(800px 520px at 80% 80%, rgb(99 102 241 / 20%), transparent 65%);
    pointer-events: none;
  }

  .sfp__hero,
  .sfp__section,
  .sfp__tools,
  .sfp__ticker,
  .sfp__final {
    max-width: 1120px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .sfp__hero {
    padding-top: 2rem;
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    gap: 1.8rem;
    align-items: center;
  }

  .sfp__glass {
    border: 1px solid rgb(0 245 255 / 32%);
    border-radius: 20px;
    background: linear-gradient(150deg, rgb(17 28 52 / 78%), rgb(14 23 43 / 58%));
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 12%), 0 18px 32px rgb(0 0 0 / 34%);
  }

  .sfp__hero-media {
    padding: 1rem;
  }

  .sfp__hero-media-inner {
    border-radius: 14px;
    min-height: 430px;
    background: #0b1429;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .sfp__hero-image,
  .sfp__hero-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sfp h1 {
    margin: 0.55rem 0 0;
    font: 800 clamp(2.2rem, 7vw, 4.3rem) / 0.97 Outfit, Inter, sans-serif;
    max-width: 18ch;
  }

  .sfp__chip {
    display: inline-flex;
    border-radius: 999px;
    border: 1px solid rgb(0 245 255 / 34%);
    background: rgb(8 17 36 / 82%);
    color: #d7f9ff;
    padding: 0.32rem 0.82rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .sfp__desc {
    margin: 0.8rem 0 0;
    color: var(--muted);
    line-height: 1.55;
    max-width: 62ch;
  }

  .sfp__rating-line {
    margin-top: 0.85rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.86rem;
  }

  .sfp__stars {
    color: var(--cyan);
    letter-spacing: 0.05em;
  }

  .sfp__price-line {
    margin-top: 0.7rem;
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
  }

  .sfp__price {
    color: #fff;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1;
  }

  .sfp__compare {
    color: #97a6ba;
    text-decoration: line-through;
  }

  .sfp__benefits {
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.35rem;
  }

  .sfp__benefits li {
    position: relative;
    padding-left: 1.1rem;
    color: #d6e4f4;
    font-size: 0.93rem;
  }

  .sfp__benefits li::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--cyan);
    position: absolute;
    left: 0;
    top: 0.46rem;
    box-shadow: 0 0 10px rgb(0 245 255 / 60%);
  }

  .sfp__form {
    margin-top: 0.95rem;
    display: grid;
    gap: 0.6rem;
  }

  .sfp__select {
    min-height: 44px;
    border-radius: 12px;
    border: 1px solid rgb(255 255 255 / 20%);
    background: rgb(10 19 38 / 80%);
    color: #fff;
    padding: 0.6rem 0.75rem;
  }

  .sfp__cta {
    min-height: 52px;
    border-radius: 12px;
    border: 0;
    padding: 0.82rem 1.1rem;
    color: #031018;
    font-weight: 800;
    background: linear-gradient(90deg, var(--cyan), var(--indigo));
    box-shadow: 0 0 20px rgb(0 245 255 / 28%);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .sfp__security {
    margin: 0.65rem 0 0;
    color: #9db0c9;
    font-size: 0.78rem;
    text-align: center;
  }

  .sfp__ticker {
    margin-top: 1rem;
    padding: 0.5rem 0.9rem;
  }

  .sfp__ticker p {
    margin: 0;
    text-align: center;
    font-weight: 700;
    color: #e9f5ff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sfp__section {
    margin-top: 0;
    padding-top: 3.1rem;
    text-align: center;
    border-top: 1px solid rgb(255 255 255 / 8%);
  }

  .sfp h2 {
    margin: 0.72rem 0 0;
    font: 800 clamp(2rem, 6vw, 3.7rem) / 1.06 Outfit, Inter, sans-serif;
  }

  .sfp__section-sub {
    margin: 0.85rem auto 0;
    max-width: 760px;
    color: var(--muted);
    line-height: 1.52;
  }

  .sfp__features-grid {
    margin-top: 1.7rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .sfp__feature-card {
    padding: 1.15rem;
    text-align: left;
  }

  .sfp__emoji {
    margin: 0 0 0.6rem;
    font-size: 1.35rem;
  }

  .sfp__feature-card h3 {
    margin: 0;
    font: 700 clamp(1.05rem, 2.3vw, 1.35rem) / 1.25 Outfit, Inter, sans-serif;
  }

  .sfp__feature-card p {
    margin: 0.6rem 0 0;
    color: #9fb0c6;
    line-height: 1.55;
  }

  .sfp__reviews-score {
    margin-top: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .sfp__score {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
  }

  .sfp__reviews-grid {
    margin-top: 1.3rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .sfp__review-card {
    padding: 1rem;
    text-align: left;
  }

  .sfp__review-top {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .sfp__avatar {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: linear-gradient(90deg, var(--cyan), var(--indigo));
    color: #031018;
    font-weight: 800;
    font-size: 0.8rem;
  }

  .sfp__review-card h3 {
    margin: 0;
    font-size: 0.95rem;
  }

  .sfp__location {
    margin: 0;
    color: #88a0be;
    font-size: 0.78rem;
  }

  .sfp__review-meta {
    margin: 0.65rem 0 0;
    font-size: 0.78rem;
    color: #c7d8ec;
    display: flex;
    justify-content: space-between;
  }

  .sfp__review-text {
    margin: 0.62rem 0 0;
    color: #a9b8cc;
    line-height: 1.5;
    font-size: 0.92rem;
  }

  .sfp__verified {
    margin: 0.8rem 0 0;
    color: #80f4b1;
    font-size: 0.75rem;
    font-weight: 700;
    background: rgb(34 197 94 / 14%);
    border: 1px solid rgb(34 197 94 / 25%);
    border-radius: 999px;
    padding: 0.28rem 0.65rem;
    display: inline-flex;
  }

  .sfp__numbers-grid {
    margin-top: 1.3rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .sfp__number-card {
    padding: 1.15rem;
    text-align: left;
  }

  .sfp__number-card h3 {
    margin: 0;
    color: #35d9ff;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1;
  }

  .sfp__number-label {
    margin: 0.6rem 0 0;
    color: #e8f1ff;
    font-weight: 700;
  }

  .sfp__numbers-grid .sfp__number-card:nth-child(4) {
    grid-column: 1 / -1;
  }

  .sfp__tools {
    margin-top: 2.4rem;
    padding: 1.2rem 1rem;
    text-align: center;
    border-top: 1px solid rgb(255 255 255 / 8%);
  }

  .sfp__tools-title {
    margin: 0;
    color: #9db1ca;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .sfp__tools-row {
    margin-top: 0.9rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .sfp__tool-pill {
    border: 1px solid rgb(0 245 255 / 33%);
    border-radius: 999px;
    padding: 0.28rem 0.72rem;
    color: #dfebff;
    font-size: 0.74rem;
    background: rgb(9 18 38 / 86%);
  }

  .sfp__faq-list {
    margin-top: 1.35rem;
    display: grid;
    gap: 0.75rem;
  }

  .sfp__faq-item {
    padding: 0.95rem 1rem;
    text-align: left;
  }

  .sfp__faq-item summary {
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    position: relative;
    padding-right: 1.8rem;
  }

  .sfp__faq-item summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 0;
    color: var(--cyan);
    font-size: 1.2rem;
    line-height: 1;
  }

  .sfp__faq-item p {
    margin: 0.72rem 0 0;
    color: #9eb1c8;
  }

  .sfp__final {
    margin-top: 3rem;
    text-align: center;
    max-width: 1120px;
    padding: 2.2rem 1.4rem 1.8rem;
    position: relative;
    z-index: 1;
    border-top: 0;
    background: transparent;
    box-shadow: none;
  }

  .sfp__offer-price {
    margin-top: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .sfp__old {
    color: #8ea0b9;
    text-decoration: line-through;
    font-size: 1.8rem;
  }

  .sfp__new {
    color: #f8fbff;
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
  }

  .sfp__save {
    border-radius: 999px;
    padding: 0.27rem 0.66rem;
    background: rgb(0 245 255 / 17%);
    border: 1px solid rgb(0 245 255 / 35%);
    color: #0ef7ff;
    font-size: 0.74rem;
    font-weight: 800;
  }

  .sfp__cta--final {
    margin-top: 1rem;
    min-width: 260px;
  }

  .sfp__final-trust {
    margin-top: 1rem;
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    color: #99aec8;
    font-size: 0.8rem;
  }

  .sfp__urgency {
    margin-top: 0.7rem;
    color: #f7cc78;
    font-size: 0.79rem;
  }

  @media screen and (max-width: 980px) {
    .sfp__hero {
      grid-template-columns: 1fr;
    }

    .sfp__hero-media-inner {
      min-height: 300px;
    }

    .sfp__reviews-grid,
    .sfp__numbers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 700px) {
    .sfp__features-grid,
    .sfp__reviews-grid,
    .sfp__numbers-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const root = document.getElementById('ScaleFlowProduct-{{ section.id }}');
    if (!root || root.dataset.sfpInit === 'true') return;
    root.dataset.sfpInit = 'true';
    const select = root.querySelector('[data-sfp-variant-select]');
    const variantInput = root.querySelector('[data-sfp-variant-id]');
    const priceNode = root.querySelector('[data-sfp-price]');
    if (!select || !variantInput || !priceNode) return;
    select.addEventListener('change', () => {
      const selected = select.options[select.selectedIndex];
      variantInput.value = selected.value;
      if (selected.dataset.price) priceNode.textContent = selected.dataset.price;
    });
  })();
</script>

{% schema %}
{
  "name": "Scale Flow Product",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "TOOLKIT DIGITAL · IA + CONTENIDO" },
    { "type": "text", "id": "compare_price_text", "label": "Precio comparativo", "default": "valor €79" },
    { "type": "text", "id": "benefit_1", "label": "Beneficio 1", "default": "Acceso inmediato" },
    { "type": "text", "id": "benefit_2", "label": "Beneficio 2", "default": "Actualizaciones de por vida" },
    { "type": "text", "id": "benefit_3", "label": "Beneficio 3", "default": "Compatible con ChatGPT, Midjourney, Canva" },
    { "type": "text", "id": "cta_text", "label": "Texto CTA compra", "default": "Obtener Acceso Ahora" },
    { "type": "text", "id": "security_text", "label": "Texto seguridad", "default": "Pago seguro · 30 días de garantía" },
    { "type": "text", "id": "ticker_text", "label": "Ticker", "default": "⚡ +12.000 fundadores ya están escalando · 🔥 247 copias vendidas este mes · ⭐ Valoración media 4.9/5" },
    { "type": "text", "id": "extras_kicker", "label": "Kicker features", "default": "LO QUE OBTIENES" },
    { "type": "text", "id": "extras_title", "label": "Titulo features", "default": "Todo lo que incluye el Toolkit" },
    { "type": "textarea", "id": "extras_text", "label": "Texto features", "default": "Un arsenal completo para dominar la creación de contenido visual con inteligencia artificial." },
    { "type": "text", "id": "reviews_kicker", "label": "Kicker reviews", "default": "RESEÑAS VERIFICADAS" },
    { "type": "text", "id": "reviews_title", "label": "Titulo reviews", "default": "Lo que dicen nuestros clientes" },
    { "type": "text", "id": "numbers_kicker", "label": "Kicker numbers", "default": "PROOF IN NUMBERS" },
    { "type": "text", "id": "numbers_title", "label": "Titulo numbers", "default": "Números que hablan solos" },
    { "type": "text", "id": "tools_kicker", "label": "Kicker tools", "default": "COMPATIBLE CON LAS MEJORES HERRAMIENTAS" },
