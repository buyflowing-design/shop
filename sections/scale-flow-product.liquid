{% liquid
  assign current_variant = product.selected_or_first_available_variant
%}

<section
  id="ScaleFlowProduct-{{ section.id }}"
  class="sf-product spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="sf-product__texture"></div>
  <div class="sf-product__inner">
    <div class="sf-product__media sf-product__glass">
      {% if product.featured_media %}
        {% assign media = product.featured_media.preview_image %}
        {{
          media
          | image_url: width: 1800
          | image_tag:
            class: 'sf-product__image',
            loading: 'eager',
            fetchpriority: 'high',
            widths: '480, 720, 1080, 1500, 1800',
            alt: media.alt | default: product.title
        }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'sf-product__placeholder' }}
      {% endif %}
    </div>

    <div class="sf-product__content sf-product__glass">
      {% if section.settings.kicker != blank %}
        <p class="sf-product__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      <h1>{{ product.title }}</h1>
      {% if product.description != blank %}
        <div class="sf-product__description">
          {{ product.description | strip_html | truncatewords: 34 }}
        </div>
      {% endif %}

      <div class="sf-product__social-proof">
        <span class="sf-product__stars">★★★★★</span>
        <span>{{ section.settings.rating_text }}</span>
      </div>

      <div class="sf-product__price-wrap">
        <span class="sf-product__price" data-sf-price>{{ current_variant.price | money }}</span>
        {% if section.settings.compare_price_text != blank %}
          <span class="sf-product__compare">{{ section.settings.compare_price_text }}</span>
        {% endif %}
      </div>

      {% if section.settings.benefit_1 != blank or section.settings.benefit_2 != blank or section.settings.benefit_3 != blank %}
        <ul class="sf-product__benefits">
          {% if section.settings.benefit_1 != blank %}<li>{{ section.settings.benefit_1 }}</li>{% endif %}
          {% if section.settings.benefit_2 != blank %}<li>{{ section.settings.benefit_2 }}</li>{% endif %}
          {% if section.settings.benefit_3 != blank %}<li>{{ section.settings.benefit_3 }}</li>{% endif %}
        </ul>
      {% endif %}

      {% form 'product', product, class: 'sf-product__form', data-sf-product-form: '' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-sf-variant-id>

        {% if product.has_only_default_variant == false %}
          <label class="sf-product__label" for="Variant-{{ section.id }}">Variante</label>
          <select id="Variant-{{ section.id }}" class="sf-product__select" data-sf-variant-select>
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                data-price-formatted="{{ variant.price | money }}"
                {% if variant.id == current_variant.id %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }}{% unless variant.available %} - Agotado{% endunless %}
              </option>
            {% endfor %}
          </select>
        {% endif %}

        <label class="sf-product__label" for="Quantity-{{ section.id }}">Cantidad</label>
        <input id="Quantity-{{ section.id }}" class="sf-product__qty" type="number" name="quantity" min="1" value="1">

        <button type="submit" class="sf-product__cta" {% unless current_variant.available %}disabled{% endunless %}>
          {% if current_variant.available %}
            {{ section.settings.cta_text }}
          {% else %}
            Agotado
          {% endif %}
        </button>
      {% endform %}

      {% if section.settings.security_text != blank %}
        <p class="sf-product__security">{{ section.settings.security_text }}</p>
      {% endif %}
    </div>
  </div>

  {% if section.blocks.size > 0 %}
    <div class="sf-product__extras sf-product__glass">
      <div class="sf-product__extras-heading">
        <p>{{ section.settings.extras_kicker }}</p>
        <h2>{{ section.settings.extras_title }}</h2>
        <p>{{ section.settings.extras_text }}</p>
      </div>
      <div class="sf-product__extras-grid">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <article class="sf-product__extra-card" {{ block.shopify_attributes }}>
              <p class="sf-product__emoji">{{ block.settings.emoji }}</p>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="sf-product__ticker sf-product__glass">
    <p>{{ section.settings.ticker_text }}</p>
  </div>

  <div class="sf-product__reviews sf-product__glass">
    <div class="sf-product__extras-heading">
      <p>{{ section.settings.reviews_kicker }}</p>
      <h2>{{ section.settings.reviews_title }}</h2>
      <p>{{ section.settings.reviews_text }}</p>
    </div>
    <div class="sf-product__reviews-grid">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <article class="sf-product__review-card" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.author }}</h3>
            <p class="sf-product__review-location">{{ block.settings.location }}</p>
            <p class="sf-product__review-meta">{{ block.settings.when }} · {{ block.settings.verification }}</p>
            <p>{{ block.settings.quote }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sf-product__numbers sf-product__glass">
    <div class="sf-product__extras-heading">
      <p>{{ section.settings.numbers_kicker }}</p>
      <h2>{{ section.settings.numbers_title }}</h2>
    </div>
    <div class="sf-product__numbers-grid">
      {% for block in section.blocks %}
        {% if block.type == 'number' %}
          <article class="sf-product__number-card" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.metric }}</h3>
            <p>{{ block.settings.label }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sf-product__faq sf-product__glass">
    <div class="sf-product__extras-heading">
      <p>{{ section.settings.faq_kicker }}</p>
      <h2>{{ section.settings.faq_title }}</h2>
    </div>
    <div class="sf-product__faq-list">
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}
          <details class="sf-product__faq-item" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <p>{{ block.settings.answer }}</p>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sf-product__tools sf-product__glass">
    <div class="sf-product__extras-heading">
      <p>{{ section.settings.tools_kicker }}</p>
      <h2>{{ section.settings.tools_title }}</h2>
    </div>
    <div class="sf-product__tools-grid">
      {% for block in section.blocks %}
        {% if block.type == 'tool' %}
          <article class="sf-product__tool-item" {{ block.shopify_attributes }}>
            {{ block.settings.name }}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sf-product__final sf-product__glass">
    <p class="sf-product__offer-kicker">{{ section.settings.offer_kicker }}</p>
    <h2>{{ section.settings.final_title }}</h2>
    <p>{{ section.settings.final_text }}</p>
    <div class="sf-product__offer-price">
      <span class="sf-product__offer-old">{{ section.settings.offer_old_price }}</span>
      <span class="sf-product__offer-new">{{ section.settings.offer_new_price }}</span>
      <span class="sf-product__offer-save">{{ section.settings.offer_save }}</span>
    </div>
    <a href="{{ product.url }}?variant={{ current_variant.id }}" class="sf-product__cta">{{ section.settings.final_cta }}</a>
    <p class="sf-product__offer-urgency">{{ section.settings.offer_urgency }}</p>
  </div>
</section>

{% stylesheet %}
  .sf-product {
    --sf-bg: #050505;
    --sf-glass: rgb(30 41 59 / 60%);
    --sf-cyan: #00f5ff;
    --sf-indigo: #6366f1;
    --sf-title: #fff;
    --sf-body: #94a3b8;
    position: relative;
    overflow: clip;
    background: radial-gradient(circle at 20% 12%, rgb(0 245 255 / 10%), transparent 40%),
      radial-gradient(circle at 88% 2%, rgb(99 102 241 / 14%), transparent 36%), var(--sf-bg);
    color: var(--sf-body);
    padding-inline: clamp(1rem, 3vw, 3rem);
  }

  .sf-product__texture {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: linear-gradient(rgb(255 255 255 / 2%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / 2%) 1px, transparent 1px);
    background-size: 42px 42px;
    opacity: 0.22;
  }

  .sf-product__inner,
  .sf-product__extras {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin-inline: auto;
  }

  .sf-product__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .sf-product__glass {
    border: 1px solid rgb(255 255 255 / 13%);
    background: linear-gradient(140deg, rgb(30 41 59 / 68%), rgb(30 41 59 / 40%));
    backdrop-filter: blur(16px);
    border-radius: 24px;
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 20%), 0 20px 40px rgb(0 0 0 / 42%);
  }

  .sf-product__media {
    overflow: hidden;
    min-height: 520px;
  }

  .sf-product__image,
  .sf-product__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sf-product__content {
    padding: clamp(1.1rem, 2.8vw, 2rem);
  }

  .sf-product__kicker {
    margin: 0 0 0.5rem;
    color: var(--sf-cyan);
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .sf-product h1,
  .sf-product h2,
  .sf-product h3 {
    margin: 0;
    color: var(--sf-title);
    font-family: Outfit, Syne, "Segoe UI", sans-serif;
  }

  .sf-product h1 {
    font-size: clamp(1.7rem, 3.2vw, 2.8rem);
    line-height: 1.13;
    margin-bottom: 0.75rem;
  }

  .sf-product__description {
    line-height: 1.55;
    margin-bottom: 0.8rem;
  }

  .sf-product__social-proof {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.92rem;
    margin-bottom: 0.9rem;
  }

  .sf-product__stars {
    color: #f6d365;
    letter-spacing: 0.04em;
  }

  .sf-product__price-wrap {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }

  .sf-product__price {
    color: var(--sf-cyan);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 800;
    line-height: 1;
  }

  .sf-product__compare {
    color: rgb(148 163 184 / 80%);
    font-size: 0.9rem;
    text-decoration: line-through;
  }

  .sf-product__benefits {
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.4rem;
  }

  .sf-product__benefits li {
    position: relative;
    padding-left: 1.1rem;
  }

  .sf-product__benefits li::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--sf-cyan);
    box-shadow: 0 0 12px rgb(0 245 255 / 58%);
    position: absolute;
    top: 0.45rem;
    left: 0;
  }

  .sf-product__form {
    display: grid;
    gap: 0.55rem;
  }

  .sf-product__label {
    font-size: 0.85rem;
    color: #d8e5f5;
  }

  .sf-product__select,
  .sf-product__qty {
    min-height: 44px;
    border-radius: 12px;
    border: 1px solid rgb(255 255 255 / 18%);
    background: rgb(15 23 42 / 62%);
    color: #fff;
    padding: 0.6rem 0.7rem;
  }

  .sf-product__cta {
    margin-top: 0.35rem;
    border: 0;
    border-radius: 14px;
    min-height: 48px;
    font-weight: 700;
    color: #05121f;
    background: linear-gradient(120deg, var(--sf-cyan), var(--sf-indigo));
    box-shadow: 0 0 20px rgb(0 245 255 / 34%);
    cursor: pointer;
    transition: transform 120ms ease, box-shadow 140ms ease;
  }

  .sf-product__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 26px rgb(99 102 241 / 45%);
  }

  .sf-product__cta:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .sf-product__security {
    margin: 0.75rem 0 0;
    color: #cde8f1;
    font-size: 0.86rem;
  }

  .sf-product__extras {
    margin-top: clamp(1rem, 3vw, 1.5rem);
    padding: clamp(1.1rem, 3vw, 1.8rem);
  }

  .sf-product__ticker,
  .sf-product__reviews,
  .sf-product__numbers,
  .sf-product__faq,
  .sf-product__tools,
  .sf-product__final {
    margin-top: 1rem;
    max-width: 1240px;
    margin-inline: auto;
    padding: clamp(1rem, 2.6vw, 1.6rem);
    position: relative;
    z-index: 1;
  }

  .sf-product__ticker p {
    margin: 0;
    text-align: center;
    color: #d8f7fa;
    font-weight: 700;
  }

  .sf-product__extras-heading {
    text-align: center;
    margin-bottom: 1rem;
  }

  .sf-product__extras-heading p:first-child {
    margin: 0;
    color: var(--sf-cyan);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .sf-product__extras-heading h2 {
    margin: 0.45rem 0;
    font-size: clamp(1.4rem, 3vw, 2.1rem);
  }

  .sf-product__extras-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .sf-product__extra-card {
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 16px;
    background: rgb(15 23 42 / 45%);
    padding: 1rem;
  }

  .sf-product__emoji {
    margin: 0 0 0.45rem;
    font-size: 1.2rem;
  }

  .sf-product__extra-card h3 {
    margin-bottom: 0.35rem;
    font-size: 1.05rem;
  }

  .sf-product__extra-card p {
    margin: 0;
    line-height: 1.5;
  }

  .sf-product__reviews-grid,
  .sf-product__numbers-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .sf-product__review-card,
  .sf-product__number-card {
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 16px;
    background: rgb(15 23 42 / 45%);
    padding: 1rem;
  }

  .sf-product__review-card h3,
  .sf-product__number-card h3 {
    margin: 0;
    color: #fff;
  }

  .sf-product__review-location {
    margin: 0.25rem 0 0.6rem;
    color: var(--sf-cyan);
    font-size: 0.85rem;
  }

  .sf-product__review-meta {
    margin: 0 0 0.55rem;
    color: #c0d4ea;
    font-size: 0.8rem;
  }

  .sf-product__number-card {
    text-align: center;
  }

  .sf-product__number-card h3 {
    color: var(--sf-cyan);
    font-size: clamp(1.5rem, 3vw, 2.3rem);
  }

  .sf-product__faq-list {
    display: grid;
    gap: 0.65rem;
  }

  .sf-product__faq-item {
    border: 1px solid rgb(255 255 255 / 12%);
    border-radius: 12px;
    padding: 0.8rem;
    background: rgb(15 23 42 / 42%);
  }

  .sf-product__faq-item summary {
    cursor: pointer;
    color: #fff;
    font-weight: 600;
  }

  .sf-product__faq-item p {
    margin: 0.6rem 0 0;
  }

  .sf-product__tools-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .sf-product__tool-item {
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 12px;
    background: rgb(15 23 42 / 45%);
    padding: 0.7rem 0.9rem;
    text-align: center;
    color: #dce7f4;
    font-weight: 600;
  }

  .sf-product__final {
    text-align: center;
  }

  .sf-product__offer-kicker {
    margin: 0;
    color: #ff9d5c;
    font-weight: 700;
  }

  .sf-product__offer-price {
    margin: 0.6rem 0 0.8rem;
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .sf-product__offer-old {
    text-decoration: line-through;
    color: #95a4b8;
  }

  .sf-product__offer-new {
    color: var(--sf-cyan);
    font-size: 1.45rem;
    font-weight: 800;
  }

  .sf-product__offer-save {
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    background: rgb(0 245 255 / 14%);
    color: var(--sf-cyan);
    font-weight: 700;
    font-size: 0.82rem;
  }

  .sf-product__offer-urgency {
    margin: 0.8rem 0 0;
    color: #f7b187;
    font-size: 0.88rem;
  }

  .sf-product__final h2 {
    margin: 0 0 0.4rem;
    font-size: clamp(1.5rem, 3vw, 2.3rem);
  }

  .sf-product__final p {
    margin: 0 0 1rem;
  }

  @media screen and (max-width: 980px) {
    .sf-product__inner {
      grid-template-columns: 1fr;
    }

    .sf-product__media {
      min-height: 320px;
    }

    .sf-product__extras-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sf-product__reviews-grid,
    .sf-product__numbers-grid {
      grid-template-columns: 1fr 1fr;
    }

    .sf-product__tools-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 620px) {
    .sf-product__extras-grid {
      grid-template-columns: 1fr;
    }

    .sf-product__reviews-grid,
    .sf-product__numbers-grid {
      grid-template-columns: 1fr;
    }

    .sf-product__tools-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const root = document.getElementById('ScaleFlowProduct-{{ section.id }}');
    if (!root || root.dataset.sfProductInit === 'true') return;
    root.dataset.sfProductInit = 'true';

    const select = root.querySelector('[data-sf-variant-select]');
    const variantInput = root.querySelector('[data-sf-variant-id]');
    const priceNode = root.querySelector('[data-sf-price]');

    if (!select || !variantInput || !priceNode) return;

    select.addEventListener('change', () => {
      const selected = select.options[select.selectedIndex];
      variantInput.value = selected.value;
      if (selected.dataset.priceFormatted) {
        priceNode.textContent = selected.dataset.priceFormatted;
      }
    });
  })();
</script>

